diff --git a/drivers/bluetooth/btusb.c b/drivers/bluetooth/btusb.c
index c07d57eac..8b63c9f40 100644
--- a/drivers/bluetooth/btusb.c
+++ b/drivers/bluetooth/btusb.c
@@ -65,6 +65,8 @@ static struct usb_driver btusb_driver;
 #define BTUSB_INTEL_BROKEN_INITIAL_NCMD BIT(25)
 #define BTUSB_INTEL_NO_WBS_SUPPORT	BIT(26)
 #define BTUSB_ACTIONS_SEMI		BIT(27)
+#define BTUSB_BROKEN_LOCAL_EXT_FEATURES BIT(28)
+#define BTUSB_BARROT_BR8554		BIT(29)
 
 static const struct usb_device_id btusb_table[] = {
 	/* Generic Bluetooth USB device */
@@ -799,6 +801,10 @@ static const struct usb_device_id quirks_table[] = {
 	/* Actions Semiconductor ATS2851 based devices */
 	{ USB_DEVICE(0x10d7, 0xb012), .driver_info = BTUSB_ACTIONS_SEMI },
 
+	/* Barrot BR8554 based devices */
+	{ USB_DEVICE(0x33fa, 0x0010), .driver_info = BTUSB_BARROT_BR8554 },
+	{ USB_DEVICE(0x33fa, 0x0012), .driver_info = BTUSB_BARROT_BR8554 },
+
 	/* Silicon Wave based devices */
 	{ USB_DEVICE(0x0c10, 0x0000), .driver_info = BTUSB_SWAVE },
 
@@ -4057,6 +4063,20 @@ static int btusb_probe(struct usb_interface *intf,
 	if (id->driver_info & BTUSB_INVALID_LE_STATES)
 		set_bit(HCI_QUIRK_BROKEN_LE_STATES, &hdev->quirks);
 
+	if (id->driver_info & BTUSB_BROKEN_LOCAL_EXT_FEATURES)
+		set_bit(HCI_QUIRK_BROKEN_LOCAL_EXT_FEATURES, &hdev->quirks);
+
+	if (id->driver_info & BTUSB_BARROT_BR8554) {
+		bt_dev_info(hdev, "enabling Barrot BR8554 init quirks");
+		set_bit(HCI_QUIRK_BROKEN_LOCAL_EXT_FEATURES, &hdev->quirks);
+		set_bit(HCI_QUIRK_BROKEN_LOCAL_EXT_FEATURES_PAGE_2, &hdev->quirks);
+		set_bit(HCI_QUIRK_BROKEN_READ_LOCAL_NAME, &hdev->quirks);
+		set_bit(HCI_QUIRK_BROKEN_STORED_LINK_KEY, &hdev->quirks);
+		set_bit(HCI_QUIRK_BROKEN_FILTER_CLEAR_ALL, &hdev->quirks);
+		set_bit(HCI_QUIRK_BROKEN_ERR_DATA_REPORTING, &hdev->quirks);
+		set_bit(HCI_QUIRK_NO_SUSPEND_NOTIFIER, &hdev->quirks);
+	}
+
 	if (id->driver_info & BTUSB_DIGIANSWER) {
 		data->cmdreq_type = USB_TYPE_VENDOR;
 		set_bit(HCI_QUIRK_RESET_ON_CLOSE, &hdev->quirks);
diff --git a/include/net/bluetooth/hci.h b/include/net/bluetooth/hci.h
index 4b3200542..eac750c90 100644
--- a/include/net/bluetooth/hci.h
+++ b/include/net/bluetooth/hci.h
@@ -286,6 +286,21 @@ enum {
 	 */
 	HCI_QUIRK_BROKEN_MWS_TRANSPORT_CONFIG,
 
+	/*
+	 * Some controllers like the Barrot BR8554 (33fa:0010/0012) are non
+	 * compliant and timeout when HCI_OP_READ_LOCAL_EXT_FEATURES is sent.
+	 * Setting this quirk skips the read and lets the device finish
+	 * initialization.
+	 */
+	HCI_QUIRK_BROKEN_LOCAL_EXT_FEATURES,
+
+	/*
+	 * Some controllers falsely advertise BR/EDR local-name support but
+	 * timeout or wedge when HCI_OP_READ_LOCAL_NAME is sent during init.
+	 * Setting this quirk skips that non-essential startup read.
+	 */
+	HCI_QUIRK_BROKEN_READ_LOCAL_NAME,
+
 	/* When this quirk is set, max_page for local extended features
 	 * is set to 1, even if controller reports higher number. Some
 	 * controllers (e.g. RTL8723CS) report more pages, but they
diff --git a/net/bluetooth/hci_sync.c b/net/bluetooth/hci_sync.c
index 80eab1d0e..c3fc5d4de 100644
--- a/net/bluetooth/hci_sync.c
+++ b/net/bluetooth/hci_sync.c
@@ -3779,0 +3780,3 @@ static int hci_read_local_name_sync(struct hci_dev *hdev)
+	if (test_bit(HCI_QUIRK_BROKEN_READ_LOCAL_NAME, &hdev->quirks))
+		return 0;
+
@@ -3956,0 +3960,3 @@ static int hci_read_local_ext_features_1_sync(struct hci_dev *hdev)
+	if (test_bit(HCI_QUIRK_BROKEN_LOCAL_EXT_FEATURES, &hdev->quirks))
+		return 0;
+
